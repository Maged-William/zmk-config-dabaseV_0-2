#include <physical_layouts.dtsi>

/ {
    dabase_layout: dabase_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default";

        //                       w   h   x   y   rot rx  ry
        keys
            = <&key_physical_attrs 100 100 0 0 0 0 0>,  // ▽
              <&key_physical_attrs 100 100 100 0 0 0 0>,  // Q
              <&key_physical_attrs 100 100 200 0 0 0 0>,  // W
              <&key_physical_attrs 100 100 300 0 0 0 0>,  // F
              <&key_physical_attrs 100 100 400 0 0 0 0>,  // P
              <&key_physical_attrs 100 100 500 0 0 0 0>,  // B

              <&key_physical_attrs 100 100 700 0 0 0 0>,  // J
              <&key_physical_attrs 100 100 800 0 0 0 0>,  // L
              <&key_physical_attrs 100 100 900 0 0 0 0>,  // U
              <&key_physical_attrs 100 100 1000 0 0 0 0>,  // Y
              <&key_physical_attrs 100 100 1100 0 0 0 0>,  // ;
              <&key_physical_attrs 100 100 1200 0 0 0 0>,  // ▽

              <&key_physical_attrs 100 100 0   100 0 0 0>,  // ▽
              <&key_physical_attrs 100 100 100 100 0 0 0>,  // A
              <&key_physical_attrs 100 100 200 100 0 0 0>,  // S
              <&key_physical_attrs 100 100 300 100 0 0 0>,  // R
              <&key_physical_attrs 100 100 400 100 0 0 0>,  // T
              <&key_physical_attrs 100 100 500 100 0 0 0>,  // G

              <&key_physical_attrs 100 100 700  100 0 0 0>,  // M
              <&key_physical_attrs 100 100 800  100 0 0 0>,  // N
              <&key_physical_attrs 100 100 900  100 0 0 0>,  // E
              <&key_physical_attrs 100 100 1000 100 0 0 0>,  // I
              <&key_physical_attrs 100 100 1100 100 0 0 0>,  // O
              <&key_physical_attrs 100 100 1200 100 0 0 0>,  // ▽

              <&key_physical_attrs 100 100 0   200 0 0 0>,  // ▽
              <&key_physical_attrs 100 100 100 200 0 0 0>,  // Z
              <&key_physical_attrs 100 100 200 200 0 0 0>,  // X
              <&key_physical_attrs 100 100 300 200 0 0 0>,  // C
              <&key_physical_attrs 100 100 400 200 0 0 0>,  // D
              <&key_physical_attrs 100 100 500 200 0 0 0>,  // V

              <&key_physical_attrs 100 100 700  200 0 0 0>,  // K
              <&key_physical_attrs 100 100 800  200 0 0 0>,  // H
              <&key_physical_attrs 100 100 900  200 0 0 0>,  // ,
              <&key_physical_attrs 100 100 1000 200 0 0 0>,  // .
              <&key_physical_attrs 100 100 1100 200 0 0 0>,  // /
              <&key_physical_attrs 100 100 1200 200 0 0 0>,  // ▽

              <&key_physical_attrs 100 100 0   300 0 0 0>,  // ▽
              <&key_physical_attrs 100 100 100 300 0 0 0>,  // ▽
              <&key_physical_attrs 100 100 200 300 0 0 0>,  // mute
              <&key_physical_attrs 100 100 300 300 0 0 0>,  // LT3
              <&key_physical_attrs 100 100 400 300 0 0 0>,  // MO2
              <&key_physical_attrs 100 100 500 300 0 0 0>,  // Space

              <&key_physical_attrs 100 100 700  300 0 0 0>,  // LC(Bksp)
              <&key_physical_attrs 100 100 800  300 0 0 0>,  // MO1
              <&key_physical_attrs 100 100 900  300 0 0 0>,  // Enter
              <&key_physical_attrs 100 100 1000 300 0 0 0>,  // ▽
              <&key_physical_attrs 100 100 1100 300 0 0 0>,  // ▽
              <&key_physical_attrs 100 100 1200 300 0 0 0>   // ▽
              ;
    };
};
